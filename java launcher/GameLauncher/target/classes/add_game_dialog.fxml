<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<DialogPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gamelauncher.ui.AddGameController"
            prefWidth="500" prefHeight="500"
            style="-fx-background-color: #1a1a2e;">
    
    <content>
        <VBox spacing="15" style="-fx-background-color: #1a1a2e; -fx-padding: 20;">
            
            <Label text="Add New Game" 
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
            
            <Separator style="-fx-padding: 5 0;"/>
            
            <!-- Title -->
            <VBox spacing="5">
                <Label text="Game Title *" style="-fx-text-fill: white;"/>
                <TextField fx:id="titleField" promptText="Enter game title"
                          style="-fx-background-color: #16213e; -fx-text-fill: white; -fx-prompt-text-fill: #666;"/>
            </VBox>
            
            <!-- Executable Path -->
            <VBox spacing="5">
                <Label text="Executable Path *" style="-fx-text-fill: white;"/>
                <HBox spacing="10">
                    <TextField fx:id="executablePathField" promptText="Path to .exe file" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #16213e; -fx-text-fill: white; -fx-prompt-text-fill: #666;"/>
                    <Button text="Browse..." onAction="#handleBrowseExecutable"
                           style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
                </HBox>
            </VBox>
            
            <!-- Install Directory -->
            <VBox spacing="5">
                <Label text="Installation Directory" style="-fx-text-fill: white;"/>
                <HBox spacing="10">
                    <TextField fx:id="installDirField" promptText="Game installation folder" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #16213e; -fx-text-fill: white; -fx-prompt-text-fill: #666;"/>
                    <Button text="Browse..." onAction="#handleBrowseDirectory"
                           style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
                </HBox>
            </VBox>
            
            <!-- Platform -->
            <VBox spacing="5">
                <Label text="Platform" style="-fx-text-fill: white;"/>
                <TextField fx:id="platformField" promptText="e.g., Steam, Epic, GOG, Standalone"
                          style="-fx-background-color: #16213e; -fx-text-fill: white; -fx-prompt-text-fill: #666;"/>
            </VBox>
            
            <!-- Custom Image -->
            <VBox spacing="5">
                <Label text="Custom Image (JPG)" style="-fx-text-fill: white;"/>
                <HBox spacing="10">
                    <TextField fx:id="imagePathField" promptText="Path to custom game image" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #16213e; -fx-text-fill: white; -fx-prompt-text-fill: #666;"/>
                    <Button text="Browse..." onAction="#handleBrowseImage"
                           style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
                </HBox>
            </VBox>
            
            <!-- Description -->
            <VBox spacing="5" VBox.vgrow="ALWAYS">
                <Label text="Description" style="-fx-text-fill: white;"/>
                <TextArea fx:id="descriptionArea" promptText="Enter game description (optional)" 
                         wrapText="true" VBox.vgrow="ALWAYS"
                         style="-fx-background-color: #16213e; -fx-text-fill: white; -fx-prompt-text-fill: #666;"/>
            </VBox>
            
            <!-- Required fields note -->
            <Label text="* Required fields" style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
            
            <!-- Save/Cancel controls -->
            <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 12 0 0 0;">
                <Button text="Cancel" onAction="#handleCancel" style="-fx-background-color: #888; -fx-text-fill: white;"/>
                <Button text="Save" onAction="#handleSave" style="-fx-background-color: #28a745; -fx-text-fill: white;"/>
            </HBox>
        </VBox>
    </content>
    
    <buttonTypes>
        <ButtonType fx:constant="CANCEL"/>
    </buttonTypes>
    
    <expandableContent>
        <Region/>
    </expandableContent>
    
</DialogPane>
